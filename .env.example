# GitLab Configuration (REQUIRED)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_PROJECT_ID=your-project-id

# Server Configuration
PORT=3000
NODE_ENV=development

# Scan Schedule (cron format - default: every Monday at 2 AM UTC)
SCAN_CRON=0 2 * * 1

# Green Optimization - GCP Carbon Regions Data (built-in, no API key needed)
# Override default green region recommendation:
PREFERRED_GREEN_REGION=europe-west6

# Optional: NVD API Key for CVE lookups (get free at https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=

# Hackathon: Google Cloud & Anthropic Integration
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_API_KEY=your-vertex-ai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Webhook URL for notifications
WEBHOOK_URL=

# Optional: Electricity Maps API Key for live carbon data
ELECTRICITY_MAPS_API_KEY=
# End of Config
